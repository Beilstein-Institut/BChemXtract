<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
  <!--
    Constant names in these files deliberately mirror the ChemDraw CDX SDK
    specification (e.g. CDXTag_Object, CDXProp_FontTable, LineHeight_Variable)
    so they can be cross-referenced against the official format documentation.
    CDXConstants and CDSettings expose many of these as public API, where
    renaming would be breaking; CDXMLConstants mirrors the same spec naming
    for consistency and cross-referencing.
  -->
  <suppress checks="ConstantName" files="CDXConstants\.java"/>
  <suppress checks="ConstantName" files="CDXMLConstants\.java"/>
  <suppress checks="ConstantName" files="CDSettings\.java"/>
</suppressions>
